# Austin 311 Bot — Environment Variables
# Copy this file to .env and fill in your values.

# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional: Austin Open Data app token (increases rate limits for restaurant queries)
# Get one free at https://data.austintexas.gov/profile/edit/developer_settings
AUSTIN_APP_TOKEN=your_austin_app_token_here

# Optional: path to SQLite database (default: 311_categories.db in project root)
# DB_PATH=311_categories.db

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
